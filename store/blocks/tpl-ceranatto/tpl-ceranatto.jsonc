  },

  "image#ceranatto-img-crystal": {
    "props": {
      "src": "assets/imgs/ceranatto/texture-crystal.jpg",
      "alt": "Textura macro Ceranatto Crystal Lux acabado mármol con brillo espejo",
      "blockClass": "ceranattoFinishImg"
    }
  },

  "rich-text#ceranatto-acabado-crystal-body": {
    "props": {
      "text": "### Crystal Lux\n\n*Brillo espejo. Lujo visual. Alta resistencia al rayado.*\n\nTecnología de esmalte de alta densidad. Superficie premium con mayor resistencia al rayado por contacto cotidiano, apta incluso para mesones de cocina residenciales.",
      "blockClass": "ceranattoFinishBody"
    }
  },

  "flex-layout.col#ceranatto-acabado-natural": {
    "children": ["image#ceranatto-img-natural", "rich-text#ceranatto-acabado-natural-body"],
    "props": { "blockClass": "ceranattoFinish", "width": "50%" }
  },

  "image#ceranatto-img-natural": {
