  /* ══════════════════════ FAQ (acordeón disclosure-layout) ══════════════════════
   * Mismo patrón que store/blocks/faq.jsonc pero con blockClass propios
   * para no heredar los estilos de esa página. */

  "flex-layout.row#ceranatto-faq": {
    "title": "Ceranatto - Preguntas frecuentes",
    "children": [
      "flex-layout.col#ceranatto-faq-intro",
      "flex-layout.col#ceranatto-faq-lista"
    ],
    "props": {
      "blockClass": "ceranattoFaq",
      "fullWidth": true,
      "htmlId": "faq",
      "colGap": 7
    }
  },

  "flex-layout.col#ceranatto-faq-intro": {
    "children": ["rich-text#ceranatto-faq-eyebrow", "rich-text#ceranatto-faq-title"],
    "props": {
      "blockClass": "ceranattoFaqIntro",
      "width": "40%",
      "preventVerticalStretch": true
    }
  },

  "rich-text#ceranatto-faq-eyebrow": {
    "props": { "text": "Preguntas frecuentes", "blockClass": "ceranattoEyebrow" }
  },

  "rich-text#ceranatto-faq-title": {
    "props": {
      "text": "## Todo lo que un especificador necesita saber.",
      "blockClass": "ceranattoSectionTitle"
    }
  },

  "flex-layout.col#ceranatto-faq-lista": {
    "children": ["disclosure-layout-group#ceranatto-faq"],
    "props": {
      "blockClass": "ceranattoFaqLista",
      "width": "60%",
      "preventVerticalStretch": true
    }
  },

  "disclosure-layout-group#ceranatto-faq": {
    "children": [
      "disclosure-layout#ceranatto-faq-1",
      "disclosure-layout#ceranatto-faq-2",
      "disclosure-layout#ceranatto-faq-3",
      "disclosure-layout#ceranatto-faq-4",
      "disclosure-layout#ceranatto-faq-5"
    ]
  },

  "disclosure-layout#ceranatto-faq-1": {
    "props": { "animated": true },
    "children": ["disclosure-trigger#ceranatto-faq-1", "disclosure-content#ceranatto-faq-1"]
  },
  "disclosure-trigger#ceranatto-faq-1": {
    "props": { "as": "div", "blockClass": "ceranattoFaqQuestion" },
    "children": ["rich-text#ceranatto-faq-1-q", "disclosure-state-indicator#ceranatto"]
  },
  "rich-text#ceranatto-faq-1-q": {
    "props": {
      "text": "¿Qué es Ceranatto y en qué se diferencia del porcelanato?",
      "blockClass": "ceranattoFaqQ"
    }
  },
  "disclosure-content#ceranatto-faq-1": {
    "props": { "blockClass": "ceranattoFaqAnswer" },
    "children": ["rich-text#ceranatto-faq-1-a"]
  },
  "rich-text#ceranatto-faq-1-a": {
    "props": {
      "text": "Ceranatto es una categoría tecnológica de revestimiento cerámico desarrollada por Cerámica Italia. Iguala la estabilidad dimensional del porcelanato (expansión < 0.1%) y lo supera en resistencia mecánica (1500–1600 N vs. ~1300 N), añadiendo flexibilidad estructural que absorbe los movimientos naturales de los edificios.",
      "blockClass": "ceranattoFaqA"
    }
  },

  "disclosure-layout#ceranatto-faq-2": {
    "props": { "animated": true },
    "children": ["disclosure-trigger#ceranatto-faq-2", "disclosure-content#ceranatto-faq-2"]
  },
  "disclosure-trigger#ceranatto-faq-2": {
    "props": { "as": "div", "blockClass": "ceranattoFaqQuestion" },
    "children": ["rich-text#ceranatto-faq-2-q", "disclosure-state-indicator#ceranatto"]
  },
  "rich-text#ceranatto-faq-2-q": {
    "props": {
      "text": "¿La absorción de agua de Ceranatto es una desventaja en Colombia?",
      "blockClass": "ceranattoFaqQ"
    }
  },
  "disclosure-content#ceranatto-faq-2": {
    "props": { "blockClass": "ceranattoFaqAnswer" },
    "children": ["rich-text#ceranatto-faq-2-a"]
  },
  "rich-text#ceranatto-faq-2-a": {
    "props": {
      "text": "No. La exigencia de absorción menor a 0.5% aplica en zonas con temperaturas de congelamiento, donde el agua atrapada expande y fractura la baldosa. En Colombia no existen esas condiciones, por lo que la absorción controlada de Ceranatto (6–10%) mejora el anclaje químico y mecánico con el adhesivo.",
      "blockClass": "ceranattoFaqA"
    }
  },

  "disclosure-layout#ceranatto-faq-3": {
    "props": { "animated": true },
    "children": ["disclosure-trigger#ceranatto-faq-3", "disclosure-content#ceranatto-faq-3"]
  },
  "disclosure-trigger#ceranatto-faq-3": {
    "props": { "as": "div", "blockClass": "ceranattoFaqQuestion" },
    "children": ["rich-text#ceranatto-faq-3-q", "disclosure-state-indicator#ceranatto"]
  },
  "rich-text#ceranatto-faq-3-q": {
    "props": {
      "text": "¿Cuánto peso se ahorra por m² con Ceranatto?",
      "blockClass": "ceranattoFaqQ"
    }
  },
  "disclosure-content#ceranatto-faq-3": {
    "props": { "blockClass": "ceranattoFaqAnswer" },
    "children": ["rich-text#ceranatto-faq-3-a"]
  },
  "rich-text#ceranatto-faq-3-a": {
    "props": {
      "text": "Ceranatto pesa aproximadamente 20 kg/m², frente a los 25–30 kg/m² de un porcelanato típico. En una torre residencial de 30 pisos con ~22.500 m² revestidos, esto representa entre 112,5 y 225 toneladas menos de carga muerta.",
      "blockClass": "ceranattoFaqA"
    }
  },

  "disclosure-layout#ceranatto-faq-4": {
    "props": { "animated": true },
    "children": ["disclosure-trigger#ceranatto-faq-4", "disclosure-content#ceranatto-faq-4"]
  },
  "disclosure-trigger#ceranatto-faq-4": {
    "props": { "as": "div", "blockClass": "ceranattoFaqQuestion" },
    "children": ["rich-text#ceranatto-faq-4-q", "disclosure-state-indicator#ceranatto"]
  },
  "rich-text#ceranatto-faq-4-q": {
    "props": {
      "text": "¿Ceranatto sirve para exteriores y zonas húmedas?",
      "blockClass": "ceranattoFaqQ"
    }
  },
  "disclosure-content#ceranatto-faq-4": {
    "props": { "blockClass": "ceranattoFaqAnswer" },
    "children": ["rich-text#ceranatto-faq-4-a"]
  },
  "rich-text#ceranatto-faq-4-a": {
    "props": {
      "text": "Sí. El acabado Natural Touch (Tecnología Zona Dual) alcanza un coeficiente DCOF de 0.65–0.75, ideal para exteriores, baños y zonas húmedas, sin la aspereza de los antideslizantes tradicionales: es suave al tacto y totalmente trapeable.",
      "blockClass": "ceranattoFaqA"
    }
  },

  "disclosure-layout#ceranatto-faq-5": {
    "props": { "animated": true },
    "children": ["disclosure-trigger#ceranatto-faq-5", "disclosure-content#ceranatto-faq-5"]
  },
  "disclosure-trigger#ceranatto-faq-5": {
    "props": { "as": "div", "blockClass": "ceranattoFaqQuestion" },
    "children": ["rich-text#ceranatto-faq-5-q", "disclosure-state-indicator#ceranatto"]
  },
  "rich-text#ceranatto-faq-5-q": {
    "props": {
      "text": "¿Qué garantía ofrece Ceranatto?",
      "blockClass": "ceranattoFaqQ"
    }
  },
  "disclosure-content#ceranatto-faq-5": {
    "props": { "blockClass": "ceranattoFaqAnswer" },
    "children": ["rich-text#ceranatto-faq-5-a"]
  },
  "rich-text#ceranatto-faq-5-a": {
    "props": {
      "text": "Ceranatto cuenta con 10 años de garantía y el respaldo de más de 40 años de trayectoria de Cerámica Italia.",
      "blockClass": "ceranattoFaqA"
    }
  },

  "disclosure-state-indicator#ceranatto": {
    "props": {
      "Show": "icon-caret#ceranatto-down",
      "Hide": "icon-caret#ceranatto-up"
    }
  },
  "icon-caret#ceranatto-down": { "props": { "orientation": "down" } },
  "icon-caret#ceranatto-up": { "props": { "orientation": "up" } },

  /* ══════════════════════ CTA FINAL (caja oscura) ══════════════════════ */

  "flex-layout.row#ceranatto-cta": {
    "title": "Ceranatto - CTA especificación",
    "children": ["flex-layout.col#ceranatto-cta-col"],
    "props": {
      "blockClass": "ceranattoCta",
      "fullWidth": true,
      "htmlId": "contacto"
    }
  },

  "flex-layout.col#ceranatto-cta-col": {
    "children": [
      "rich-text#ceranatto-cta-eyebrow",
