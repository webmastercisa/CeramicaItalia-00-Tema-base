  "rich-text#centroayuda-tiendas-8-q": {
    "props": {
      "text": "### ¿En qué otras ciudades de Colombia hay salas de venta de Cerámica Italia?",
      "blockClass": "centroAyudaQ"
    }
  },
  "disclosure-content#centroayuda-tiendas-8": {
    "props": {
      "blockClass": "centroAyudaAnswer"
    },
    "children": [
      "rich-text#centroayuda-tiendas-8-a"
    ]
  },
  "rich-text#centroayuda-tiendas-8-a": {
    "props": {
      "text": "Llegamos a los principales rincones de Colombia a través de nuestros puntos de fábrica propios:\n\n* Pereira: Carrera 7 No. 33-49 Esquina, Barrio Primero de Febrero.\n  * *Horario:* Lunes a Viernes de 9:00 AM a 5:30 PM | Sábados de 9:00 AM a 1:30 PM.\n  * *Teléfono:* 317 646 5722.\n* Cartagena: Calle 30 # 34-27, Avenida Pedro Heredia, Alcibia.\n  * *Horario:* Lunes a Viernes de 8:30 AM a 5:00 PM | Sábados de 9:00 AM a 1:30 PM.\n  * *Teléfono:* 321 377 3247 / 317 644 2877.\n* Montería: Calle 41 No. 15E - 13, Barrio Mora (Frente al Hotel Florida Sinú).\n  * *Horario:* Lunes a Viernes de 8:00 AM a 12:00 PM y de 2:00 PM a 5:30 PM | Sábados de 8:00 AM a 12:30 PM.\n  * *Teléfono:* 321 502 4802 / 320 565 0706.\n* Valledupar: Calle 7D N° 9-09, Barrio San Carlos.\n  * *Horario:* Lunes a Viernes de 8:30 AM a 12:00 PM y de 2:00 PM a 6:00 PM | Sábados de 8:00 AM a 12:30 PM.\n  * *Teléfono:* 312 660 4136.",
      "blockClass": "centroAyudaA"
    }
  },
  "disclosure-layout#centroayuda-tiendas-9": {
    "props": {
      "animated": true
    },
    "children": [
      "disclosure-trigger#centroayuda-tiendas-9",
