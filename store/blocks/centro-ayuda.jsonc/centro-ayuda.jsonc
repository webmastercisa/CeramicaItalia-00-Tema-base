      "preventVerticalStretch": true
    }
  },
  "rich-text#centroayuda-cat-tiendas-titulo": {
    "props": {
      "text": "## Tiendas y puntos de fábrica",
      "blockClass": "centroAyudaCatTitle"
    }
  },
  "disclosure-layout#centroayuda-tiendas-1": {
    "props": {
      "animated": true
    },
    "children": [
      "disclosure-trigger#centroayuda-tiendas-1",
      "disclosure-content#centroayuda-tiendas-1"
    ]
  },
  "disclosure-trigger#centroayuda-tiendas-1": {
    "props": {
      "as": "div",
      "blockClass": "centroAyudaQuestion"
    },
    "children": [
      "rich-text#centroayuda-tiendas-1-q",
      "disclosure-state-indicator#centroayuda"
    ]
  },
  "rich-text#centroayuda-tiendas-1-q": {
    "props": {
      "text": "### ¿Qué productos y servicios encuentro en las salas de ventas de Cerámica Italia?",
      "blockClass": "centroAyudaQ"
    }
  },
  "disclosure-content#centroayuda-tiendas-1": {
    "props": {
      "blockClass": "centroAyudaAnswer"
    },
    "children": [
      "rich-text#centroayuda-tiendas-1-a"
    ]
  },
  "rich-text#centroayuda-tiendas-1-a": {
    "props": {
      "text": "En los Puntos de Fábrica y Salas de Ventas de Cerámica Italia encuentras un catálogo completo para la remodelación y acabados de tu hogar o proyecto de construcción. Nuestros asesores expertos te brindarán asesoría en diseño de interiores para que elijas entre una amplia variedad de:\n\n* Cerámica para pisos y revestimientos para paredes.\n* Porcelanatos y baldosas decorativas de alta resistencia.\n* Griferías modernas, sanitarios, lavamanos y mobiliario para baño.\n* Soluciones integrales en acabados y materiales para construcción.",
      "blockClass": "centroAyudaA"
    }
  },
  "disclosure-layout#centroayuda-tiendas-2": {
    "props": {
      "animated": true
    },
    "children": [
      "disclosure-trigger#centroayuda-tiendas-2",
      "disclosure-content#centroayuda-tiendas-2"
    ]
  },
  "disclosure-trigger#centroayuda-tiendas-2": {
    "props": {
      "as": "div",
      "blockClass": "centroAyudaQuestion"
    },
    "children": [
      "rich-text#centroayuda-tiendas-2-q",
      "disclosure-state-indicator#centroayuda"
    ]
  },
  "rich-text#centroayuda-tiendas-2-q": {
    "props": {
      "text": "### ¿Dónde comprar cerámica en Bogotá? (Puntos de Fábrica)",
      "blockClass": "centroAyudaQ"
    }
  },
  "disclosure-content#centroayuda-tiendas-2": {
    "props": {
      "blockClass": "centroAyudaAnswer"
    },
    "children": [
      "rich-text#centroayuda-tiendas-2-a"
    ]
  },
  "rich-text#centroayuda-tiendas-2-a": {
    "props": {
      "text": "Contamos con 5 salas de venta estratégicamente ubicadas en Bogotá para cubrir el área urbana y sus zonas aledañas:\n\n* Bogotá Norte:\n  * *Dirección:* Autopista Norte 137-78 de Sur a Norte, Costado Oriental.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Autopista%20Norte%20137-78%20de%20Sur%20a%20Norte%2C%20Costado%20Oriental%2C%20Bogot%C3%A1%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 5:30 PM | Sábados de 9:00 AM a 4:00 PM.\n  * *Teléfono:* 317 638 6436 / 317 435 0078.\n  * *Área de cobertura/despacho:* Suba, Usaquén, Cajicá, Cota, Chía, Zipaquirá, La Calera y Sopó.\n* Bogotá Sur (La Alquería):\n  * *Dirección:* Calle 38 A # 52C - 88, Barrio La Alquería (Edificio Rojo frente a Metro).\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Calle%2038%20A%20%23%2052C%20-%2088%2C%20Barrio%20La%20Alquer%C3%ADa%20%28Edificio%20Rojo%20frente%20a%20Metro%29%2C%20Bogot%C3%A1%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 5:30 PM | Sábados de 9:00 AM a 4:00 PM.\n  * *Teléfono:* 322 913 8175 / 317 638 4651.\n  * *Área de cobertura/despacho:* Soacha, Mosquera, Madrid, Sibaté, Funza, y localidades del sur de Bogotá.\n* Bogotá 104 (San Patricio):\n  * *Dirección:* Avenida 19 Calle 104-20, Zona D, Barrio San Patricio, Usaquén.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Avenida%2019%20Calle%20104-20%2C%20Zona%20D%2C%20Barrio%20San%20Patricio%2C%20Usaqu%C3%A9n%2C%20Bogot%C3%A1%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 6:00 PM | Sábados de 9:00 AM a 4:00 PM.\n  * *Teléfono:* 317 641 0057 / 318 811 9203.\n* Bogotá Calle 72 (Engativá):\n  * *Dirección:* Avenida Calle 72 # 82-17, Urbanización La Clarita, Engativá.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Avenida%20Calle%2072%20%23%2082-17%2C%20Urbanizaci%C3%B3n%20La%20Clarita%2C%20Engativ%C3%A1%2C%20Bogot%C3%A1%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 5:30 PM | Sábados de 9:00 AM a 4:00 PM.\n  * *Teléfono:* 317 513 8708.\n* Bogotá Suba:\n  * *Dirección:* Calle 139 # 109-03, Villa María, Suba.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Calle%20139%20%23%20109-03%2C%20Villa%20Mar%C3%ADa%2C%20Suba%2C%20Bogot%C3%A1%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 5:30 PM | Sábados de 9:00 AM a 4:00 PM.\n  * *Teléfono:* 318 811 9203 / 317 641 0057.",
      "blockClass": "centroAyudaA"
    }
  },
