  "rich-text#centroayuda-cta-sub": {
    "props": {
      "text": "Nuestro equipo te asesora en la línea nacional **018000 111 568** o visítanos en cualquiera de nuestras salas de venta.",
      "textAlignment": "CENTER",
      "textPosition": "CENTER",
      "blockClass": "centroAyudaCtaSub"
    }
  },
  "flex-layout.row#centroayuda-cta-botones": {
    "children": [
      "link#centroayuda-btn-contacto",
      "link#centroayuda-btn-tiendas"
    ],
    "props": {
      "blockClass": "centroAyudaCtaBotones",
      "preserveLayoutOnMobile": true,
      "preventHorizontalStretch": true,
      "horizontalAlign": "center",
      "colGap": 4
    }
  },
  "link#centroayuda-btn-contacto": {
    "props": {
      "href": "/contacto",
      "label": "Escríbenos",
      "displayMode": "button",
      "blockClass": "centroAyudaBtnPrimary"
    }
  },
  "link#centroayuda-btn-tiendas": {
    "props": {
      "href": "/nuestras-tiendas",
      "label": "Ver tiendas en el mapa",
      "displayMode": "button",
      "blockClass": "centroAyudaBtnGhost"
    }
  }
}
