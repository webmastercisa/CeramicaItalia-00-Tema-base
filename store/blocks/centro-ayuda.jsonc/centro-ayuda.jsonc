  "rich-text#centroayuda-tiendas-4-q": {
    "props": {
      "text": "### ¿Dónde comprar cerámica en Cali? (Punto de Fábrica)",
      "blockClass": "centroAyudaQ"
    }
  },
  "disclosure-content#centroayuda-tiendas-4": {
    "props": {
      "blockClass": "centroAyudaAnswer"
