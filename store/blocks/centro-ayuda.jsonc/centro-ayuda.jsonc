      "rich-text#centroayuda-tiendas-4-a"
    ]
  },
  "rich-text#centroayuda-tiendas-4-a": {
    "props": {
      "text": "* Sala de Ventas Cali CC IDEO:\n  * *Dirección:* Carrera 1 No. 62-80, Centro Comercial IDEO, Local 104.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Carrera%201%20No.%2062-80%2C%20Centro%20Comercial%20IDEO%2C%20Local%20104%2C%20Cali%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 9:00 AM a 6:00 PM | Sábados de 9:00 AM a 5:00 PM.\n  * *Teléfono:* 317 433 1090.",
      "blockClass": "centroAyudaA"
    }
  },
