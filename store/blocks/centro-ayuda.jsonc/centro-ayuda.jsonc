  "rich-text#centroayuda-tiendas-6-q": {
    "props": {
      "text": "### ¿Dónde comprar cerámica en Bucaramanga y Floridablanca? (Puntos de Fábrica y Outlets)",
      "blockClass": "centroAyudaQ"
    }
  },
  "disclosure-content#centroayuda-tiendas-6": {
    "props": {
      "blockClass": "centroAyudaAnswer"
    },
    "children": [
      "rich-text#centroayuda-tiendas-6-a"
    ]
  },
  "rich-text#centroayuda-tiendas-6-a": {
    "props": {
      "text": "* Bucaramanga Ricaurte:\n  * *Dirección:* Calle 61 # 17F-30, Barrio Ricaurte.\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Calle%2061%20%23%2017F-30%2C%20Barrio%20Ricaurte%2C%20Bucaramanga%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 8:30 AM a 12:00 PM y de 2:00 PM a 6:00 PM | Sábados de 9:00 AM a 1:30 PM.\n  * *Teléfono:* 317 435 0335.\n* Outlet Floridablanca:\n  * *Dirección:* Carrera 33 # 108-49, Barrio Caldas, Floridablanca (Santander).\n  * [Ver en Google Maps](https://www.google.com/maps/search/?api=1&query=Cer%C3%A1mica%20Italia%2C%20Carrera%2033%20%23%20108-49%2C%20Barrio%20Caldas%2C%20Floridablanca%20%28Santander%29%2C%20Bucaramanga%2C%20Colombia)\n  * *Horario:* Lunes a Viernes de 8:00 AM a 12:00 PM y de 2:00 PM a 5:30 PM | Sábados de 8:30 AM a 1:00 PM.",
      "blockClass": "centroAyudaA"
    }
  },
